{
  "name": "@lxcat/converter",
  "version": "0.1.0",
  "description": "Convert LXCat JSON documents to txt format",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "binaryName": "index"
  },
  "scripts": {
    "dev": "bun run build",
    "build": "napi build --release --strip --platform -o dist --dts index.d.ts --js index.js",
    "build:debug": "napi build --platform -o dist --dts index.d.ts --js index.js",
    "convert": "tsx util/convert.ts",
    "test": "tsx --test tests/valid.test.ts",
    "annotate": "reuse annotate --license=Apache-2.0 --copyright='LXCat team' -r --skip-existing --exclude-year --skip-unrecognised src tests",
    "clean": "rm -rf target dist",
    "prepublishOnly": "bun run build"
  },
  "author": "Daan Boer",
  "license": "Apache-2.0",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.4",
    "@types/bun": "^1.3.14",
    "tsx": "^4.23.1"
  }
}
